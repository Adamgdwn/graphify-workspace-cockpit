# Generated Graphify output (rebuild locally with `graphify update . --no-cluster`)
graphify-out/

# State (user data — not committed)
workspace/state/

# Connector auth tokens — never commit (also covered by workspace/state/ above)
workspace/state/connector-tokens/

# Connector config with real values (commit only .example)
config/connectors.json

# Env files (copy .env.example and fill in values — never commit real values)
.env
backend/.env
frontend/.env

# Private graph output — only workspace/demo/graph.json is committed
workspace/out/

# OS
.DS_Store

# Runtime logs
launcher/*.log
