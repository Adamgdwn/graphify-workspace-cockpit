# Native backend defaults.
# Copy this file to backend/.env for local PowerShell/manual runs.
#
# Graphify graph.json path.
# Leave blank for a fresh instance with no active graph yet.
# For the cockpit's own real graph (generated by `graphify update . --no-cluster`):
#   GRAPH_PATH=graphify-out/graph.json
# For a full workspace graph:
#   GRAPH_PATH=/path/to/workspace/out/graph.json
GRAPH_PATH=

# Directory for persistent state (decisions, recommendations, actions, sessions).
# Default: workspace/state (relative to repo root)
STATE_DIR=workspace/state

# CORS origins the backend allows. Comma-separated.
# Default: local Vite dev server on localhost or 127.0.0.1
# For hosted Docker: set to the domain or IP of the frontend
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ollama server URL. Optional -- cockpit falls back to graph-only answers when unreachable.
# Default for native local runs: http://localhost:11434
# In Docker: use http://host.docker.internal:11434 to reach Ollama on the host machine
OLLAMA_URL=http://localhost:11434

# Local chat/recommendation model. Default is tuned for this Windows install.
RECOMMEND_MODEL_DEFAULT=local-balanced:latest

# Local embedding model for semantic overlap analysis.
SEMANTIC_MODEL_DEFAULT=nomic-embed-text:latest

# Automatic graph escalation. Disabled by default so no graph content leaves the
# machine unless you explicitly configure an elevated Graphify extract backend.
GRAPH_ESCALATION_ENABLED=false
# GRAPH_ESCALATION_BACKEND=openai
# GRAPH_ESCALATION_MODEL=gpt-4.1
# GRAPH_ESCALATION_FILE_THRESHOLD=1500
# GRAPH_ESCALATION_ROOT_THRESHOLD=2
# GRAPH_ESCALATION_DECIDER_MODEL=local-balanced:latest
# GRAPH_ESCALATION_TIMEOUT=1800
# GRAPH_ESCALATION_API_TIMEOUT=600
# GRAPH_ESCALATION_MAX_CONCURRENCY=2
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=
# ANTHROPIC_MODEL=
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# API key for network-facing deployments. Leave unset for localhost-only use.
# When set, all non-health endpoints require:
#   Authorization: Bearer <key>   OR   X-API-Key: <key>
# Generate a key: python3 -c "import secrets; print(secrets.token_hex(32))"
# API_KEY=

# Domain for Caddy HTTPS (optional -- only needed with docker-compose --profile https).
# When set: Caddy obtains a Let's Encrypt TLS certificate for this domain.
# When unset: Caddy uses a self-signed localhost certificate.
# DOMAIN=cockpit.example.com

# Storage backend. Defaults to "file" (local JSON files in STATE_DIR).
# Set to "supabase" to use a Supabase database -- requires SUPABASE_URL and SUPABASE_KEY.
# STORAGE_BACKEND=file

# Supabase connection (only required when STORAGE_BACKEND=supabase).
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-or-service-role-key

# Microsoft 365 cloud connectors (SharePoint + OneNote).
# Register an app in Azure AD: https://portal.azure.com -> App registrations
# Required permissions (delegated): Files.Read.All, Notes.Read.All
# MICROSOFT_CLIENT_ID=your-azure-app-client-id
# MICROSOFT_TENANT_ID=common
