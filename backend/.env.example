# Graphify graph.json path.
# Default: workspace/demo/graph.json (bundled synthetic demo)
# For a real workspace: set to the absolute path output by `graphify update .`
GRAPH_PATH=workspace/demo/graph.json

# Directory for persistent state (decisions, recommendations, actions, sessions).
# Default: workspace/state (relative to repo root)
STATE_DIR=workspace/state

# CORS origins the backend allows. Comma-separated.
# Default: http://localhost:5173 (Vite dev server)
# For hosted Docker: set to the domain or IP of the frontend
CORS_ORIGINS=http://localhost:5173

# Ollama server URL. Optional — cockpit falls back to graph-only answers when unreachable.
# Default: http://localhost:11434
# In Docker: use http://host.docker.internal:11434 to reach Ollama on the host machine
OLLAMA_URL=http://localhost:11434

# API key for network-facing deployments. Leave unset for localhost-only use.
# When set, all non-health endpoints require:
#   Authorization: Bearer <key>   OR   X-API-Key: <key>
# Generate a key: python3 -c "import secrets; print(secrets.token_hex(32))"
# API_KEY=

# Domain for Caddy HTTPS (optional — only needed with docker-compose --profile https).
# When set: Caddy obtains a Let's Encrypt TLS certificate for this domain.
# When unset: Caddy uses a self-signed localhost certificate.
# DOMAIN=cockpit.example.com
